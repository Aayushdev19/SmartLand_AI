# ── Python ───────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────
venv/
env/
.venv/
.env/
ENV/

# ── Environment (NEVER commit) ────────────────────
.env
.env.local
.env.production
*.env

# ── ML Model files (large binaries) ──────────────
# Model files are regenerated by running train.py — no need to commit
backend/ml/model/*.pkl
backend/ml/model/*.joblib
backend/ml/model/model.pkl
backend/ml/model/label_maps.pkl

# ── Dataset ───────────────────────────────────────
# Raw dataset files — add to git only if they are public/non-sensitive
backend/ml/dataset/*.xlsx
backend/ml/dataset/*.csv
*.xlsx
*.csv

# ── Jupyter notebooks checkpoints ────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS ────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────
*.log
uvicorn.log

# ── pytest / coverage ─────────────────────────────
.pytest_cache/
.coverage
htmlcov/
